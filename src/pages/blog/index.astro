---
import { getCollection } from 'astro:content'
import BaseLayout from '../../layouts/BaseLayout.astro'

const allPosts = await getCollection('blog', ({ data }) => !data.draft)
const sortedPosts = allPosts.sort(
  (a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime()
)
---

<BaseLayout title="博客 - asdjklqwe123's Blog" description="所有博客文章">
  <h1 style="font-size:28px;margin-bottom:8px;">📚 所有文章</h1>
  <p style="color:var(--muted);margin-bottom:32px;">共 {sortedPosts.length} 篇</p>

  {
    sortedPosts.length === 0 ? (
      <p style="color:var(--muted);text-align:center;padding:48px 0;">还没有文章。</p>
    ) : (
      sortedPosts.map((post) => (
        <article class="post-card">
          <h2>
            <a href={`/blog/${post.id.replace(/\.mdx?$/, '')}`}>
              {post.data.title}
            </a>
          </h2>
          <div class="meta">
            <time datetime={post.data.publishDate.toISOString()}>
              {post.data.publishDate.toLocaleDateString('zh-CN', {
                year: 'numeric',
                month: 'long',
                day: 'numeric'
              })}
            </time>
          </div>
          <p class="description">{post.data.description}</p>
          {
            post.data.tags.length > 0 && (
              <div class="tags">
                {post.data.tags.map((tag) => <span class="tag">{tag}</span>)}
              </div>
            )
          }
        </article>
      ))
    )
  }
</BaseLayout>
